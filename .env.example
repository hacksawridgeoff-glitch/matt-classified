# Matt // Classified — Environment Variables
# Copy to .env and adjust before deploying.

# Redis password — REQUIRED.
# Generate a strong password before first run:
#   openssl rand -base64 32
# Both services read this variable; it must match on app and redis sides.
REDIS_PASSWORD=change-me-to-a-long-random-string

# Redis connection URL (uses the password above)
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Application log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Rate limiting (requests per 60-second window, per IP)
# Must match nginx limit_req_zone values.
RATE_LIMIT_POST=10
RATE_LIMIT_GET=60
RATE_LIMIT_GLOBAL=120

# Comma-separated list of trusted reverse proxy IPs / CIDR ranges.
# X-Forwarded-For is ONLY trusted when the direct TCP peer is in this list.
# Defaults cover localhost and private Docker networks (172.16/12, 10/8).
# On production: set to your nginx server's IP (e.g. 127.0.0.1).
TRUSTED_PROXIES=127.0.0.1,::1,172.16.0.0/12,10.0.0.0/8
